# =============================================================================
# .env.example — FreshAI Grocery — Local Development Environment Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  copy .env.example .env
#   2. Fill in your actual values in .env
#   3. NEVER commit .env to Git (it is already in .gitignore)
# =============================================================================


# ── MySQL Database ────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/grocery_clean?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here


# ── JWT Security ─────────────────────────────────────────────────────────────
# Generate a strong secret (min 256-bit / 32+ chars). Example command:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_at_least_256_bits_long


# ── JWT Expiration (optional — defaults shown) ────────────────────────────────
# JWT_EXPIRATION_MS=900000        # 15 minutes
# JWT_REFRESH_EXPIRATION_MS=604800000  # 7 days


# ── Gmail SMTP (optional — only needed if email features are enabled) ─────────
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx    # Gmail App Password (16 chars)
MAIL_ENABLED=false


# ── Frontend & CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
